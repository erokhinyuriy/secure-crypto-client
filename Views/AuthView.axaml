<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SecureCryptoClient.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AuthViewModel"
             x:Class="SecureCryptoClient.AuthView">
    <!-- Основной центрированный контейнер -->
       <!-- Главный контейнер, центрирующий карточку входа -->
   <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
        
        <!-- Карточка формы входа с красивым скруглением и матовым фоном -->
        <Border Background="#17212B" 
                BorderBrush="#24303F" 
                BorderThickness="1" 
                CornerRadius="12" 
                Padding="25,30">
            
            <StackPanel Spacing="15">
                
                <!-- Оригинальная иконка Telegram (Круг с вектором, как на кнопке отправки) -->
                <Border Width="64" Height="64" CornerRadius="32" Background="#5288C1" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Path Data="M2,21 L23,12 L2,3 L2,10 L17,12 L2,14 L2,21 Z"
                          Fill="White" Width="20" Height="20" Stretch="Uniform"
                          VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,0,0,1"/>
                </Border>
                
                <!-- Заголовок (РУСИФИЦИРОВАНО) -->
                <TextBlock Text="Вход в CryptoChat" 
                           FontSize="22" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           Margin="0,0,0,10"/>
                
                <!-- Поле ввода Логина (РУСИФИЦИРОВАНО) -->
                <TextBox x:Name="UsernameBox" 
                         Watermark="Имя пользователя"
                         Text="{Binding Username}"
                         Foreground="White" Background="#24303F"
                         BorderThickness="0" CornerRadius="6" Padding="12,10"/>
                
                <!-- Поле ввода Мастер-пароля (РУСИФИЦИРОВАНО) -->
                <TextBox x:Name="PasswordBox" 
                         PasswordChar="●"
                         Watermark="Мастер-пароль"
                         Text="{Binding MasterPassword}"
                         Foreground="White" Background="#24303F"
                         BorderThickness="0" CornerRadius="6" Padding="12,10"/>
                
                <!-- Галочка "Запомнить меня" (РУСИФИЦИРОВАНО) -->
                <CheckBox x:Name="RememberCheckbox" 
                          Content="Запомнить меня на этом устройстве"
                          IsChecked="{Binding RememberMe}"
                          Foreground="#7F91A4" FontSize="13" Margin="2,0,0,10"/>
                
                <!-- Главная кнопка Входа (РУСИФИЦИРОВАНО) -->
                <Button x:Name="LoginButton" 
                        Command="{Binding LoginLocal}"
                        IsEnabled="{Binding IsButtonsEnabled}"
                        Content="Войти"
                        Width="310" Height="42"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="#5288C1" Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        CornerRadius="6"/>
                
                <!-- Кнопка Регистрации (РУСИФИЦИРОВАНО) -->
                <Button x:Name="RegisterLink" 
                        Command="{Binding RegisterAndConnectAsync}"
                        IsEnabled="{Binding IsButtonsEnabled}"
                        Content="Нет учетной записи? Зарегистрироваться"
                        Width="310" Height="32"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Background="Transparent" Foreground="#5288C1"
                        FontSize="13" CornerRadius="6"/>
                
                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="ErrorMessageText" 
                           Text="{Binding StatusMessage}"
                           Foreground="#E55757" FontSize="12"
                           TextAlignment="Center" HorizontalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,5,0,0"/>
                
            </StackPanel>
        </Border>
        
    </Grid>
</UserControl>