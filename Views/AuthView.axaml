<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SecureCryptoClient.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AuthViewModel"
             x:Class="SecureCryptoClient.AuthView">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="320" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
        
        <TextBlock Grid.Row="0" Text="CryptoChat Security" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
        
        <!-- Поле Никнейма (нужно только при первой регистрации на сервере) -->
       <TextBox Grid.Row="1" Watermark="Имя пользователя (Логин / Регистрация)" Text="{Binding Username}" Margin="0,5"/>
        
        <!-- Поле Мастер-пароля -->
        <TextBox Grid.Row="2" Watermark="Мастер-пароль (шифрование диска)" Text="{Binding MasterPassword}" PasswordChar="●" IsEnabled="{Binding IsButtonsEnabled}" Margin="0,5"/>
        
        <!-- Кнопки действий -->
        <Button Grid.Row="3" Content="Войти (Расшифровать локальную БД)" Command="{Binding LoginLocal}" IsEnabled="{Binding IsButtonsEnabled}" Width="320" HorizontalContentAlignment="Center" Background="#2b579a" Foreground="White" Margin="0,10,0,5"/>
        <Button Grid.Row="4" Content="Создать новый аккаунт (Регистрация)" Command="{Binding RegisterAndConnectAsync}" IsEnabled="{Binding IsButtonsEnabled}" Width="320" HorizontalContentAlignment="Center" Margin="0,5"/>
        
        <!-- Статус-бар -->
        <TextBlock Grid.Row="5" Text="{Binding StatusMessage}" Foreground="Gray" FontSize="12" Margin="0,15,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        
    </Grid>
</UserControl>