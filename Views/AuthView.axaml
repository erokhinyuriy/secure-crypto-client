<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SecureCryptoClient.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:AuthViewModel"
             x:Class="SecureCryptoClient.AuthView">
     <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="320" 
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        
        <!-- Строка 0: Заголовок -->
        <TextBlock Grid.Row="0" Text="CryptoChat Security" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,20" HorizontalAlignment="Center"/>
        
        <!-- Строка 1: Поле ввода Логина -->
        <TextBox Grid.Row="1" Watermark="Имя пользователя (Логин / Регистрация)" Text="{Binding Username}" Margin="0,5" Foreground="White" Background="#24303F" BorderThickness="0" CornerRadius="4"/>
        
        <!-- Строка 2: Поле ввода Мастер-пароля -->
        <TextBox Grid.Row="2" Watermark="Мастер-пароль (шифрование диска)" Text="{Binding MasterPassword}" PasswordChar="●" Margin="0,5" Foreground="White" Background="#24303F" BorderThickness="0" CornerRadius="4"/>
        
        <!-- Строка 3: Галочка "Запомнить меня" (ТЕПЕРЬ ОНА НА СВОЕМ МЕСТЕ) -->
        <CheckBox Grid.Row="3" Content="Запомнить меня на этом устройстве" IsChecked="{Binding RememberMe}" Foreground="#7F91A4" FontSize="12" Margin="0,5"/>
        
        <!-- Строка 4: Кнопка Войти -->
        <Button Grid.Row="4" Content="Войти (Расшифровать локальную БД)" Command="{Binding LoginLocal}" IsEnabled="{Binding IsButtonsEnabled}" Width="320" HorizontalContentAlignment="Center" Background="#5288C1" Foreground="White" CornerRadius="4" Padding="0,10" Margin="0,10,0,5"/>
        
        <!-- Строка 5: Кнопка Регистрации -->
        <Button Grid.Row="5" Content="Создать новый аккаунт (Регистрация)" Command="{Binding RegisterAndConnectAsync}" IsEnabled="{Binding IsButtonsEnabled}" Width="320" HorizontalContentAlignment="Center" Background="#24303F" Foreground="#5288C1" BorderBrush="#5288C1" BorderThickness="1" CornerRadius="4" Padding="0,10" Margin="0,5"/>
        
        <!-- Строка 6: Статус-бар сообщений об ошибках -->
        <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Foreground="#7F91A4" FontSize="12" Margin="0,15,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        
    </Grid>
</UserControl>