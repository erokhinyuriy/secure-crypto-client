<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:SecureCryptoClient.ViewModels"
             xmlns:models="clr-namespace:SecureCryptoClient.Models"
             x:Class="SecureCryptoClient.MainChatView"
             x:DataType="vm:MainChatViewModel"
             Background="#182533">
    <Grid ColumnDefinitions="250, *">
        
        <!-- ================= СЛЕВА: ПАНЕЛЬ ЧАТОВ ================= -->
        <!-- Обернули Grid в Border, чтобы задать правую рамку-разделитель -->
        <Border Grid.Column="0" Background="#17212B" BorderBrush="#101921" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *">
                
                <!-- Поле добавления друга по Юзернейму -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="10">
                    <TextBox Grid.Column="0" Watermark="Добавить @username..." Text="{Binding NewFriendUsername}" Foreground="White" Background="#24303F" BorderThickness="0" CornerRadius="4,0,0,4" Height="32" VerticalContentAlignment="Center" FontSize="12"/>
                    <Button Grid.Column="1" Content="+" Command="{Binding AddNewChatByUsernameAsync}" Background="#5288C1" Foreground="White" Width="32" Height="32" CornerRadius="0,4,4,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold"/>
                </Grid>

                <!-- Список активных диалогов (Листбокс) -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Chats}" SelectedItem="{Binding SelectedChat}" Background="Transparent" BorderThickness="0" Margin="0,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:ChatSession">
                            <Grid RowDefinitions="Auto, Auto" Margin="5">
                                <!-- Имя контакта -->
                                <TextBlock Grid.Row="0" Text="{Binding PartnerName}" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                <!-- Превью последнего сообщения -->
                                <TextBlock Grid.Row="1" Text="{Binding LastMessage}" Foreground="#7F91A4" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ================= СПРАВА: ОКНО ПЕРЕПИСКИ ================= -->
        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Background="#0E1621">
            
            <!-- Верхняя плашка текущего чата -->
            <Border Grid.Row="0" Background="#17212B" Padding="15,10" BorderBrush="#101921" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding ChatHeader}" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </Border>

            <!-- Окно вывода сообщений -->
            <ScrollViewer Grid.Row="1" Padding="10">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <!-- Контейнер "Бабла" сообщения с тенью -->
                                <Border CornerRadius="6" Padding="10,6" MaxWidth="350" Background="#182533" BorderBrush="#2B5278" BorderThickness="1" HorizontalAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Sender}" FontSize="11" FontWeight="Bold" Foreground="#5288C1" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Text}" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" FontSize="9" Foreground="#7F91A4" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Нижняя панель ввода текста (Заменили Padding на Margin у Grid) -->
            <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Background="#17212B" Margin="0" IsVisible="{Binding IsChatSelected}">
                <TextBox Grid.Column="0" Watermark="Написать сообщение..." Text="{Binding TypedText}" Foreground="White" Background="#24303F" BorderThickness="0" CornerRadius="4" Padding="10,6" MaxHeight="60" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Content="Отправить" Command="{Binding SendMessageAsync}" Background="Transparent" Foreground="#5288C1" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
        
    </Grid>
</UserControl>