<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SecureCryptoClient.ViewModels"
             xmlns:models="using:SecureCryptoClient.Models"
             xmlns:system="using:System"
             x:Class="SecureCryptoClient.Views.MainChatView"
             x:DataType="vm:MainChatViewModel"
             Background="#182533">
    
<Grid ColumnDefinitions="260, 1, *">
        
        <!-- ================= СЛЕВА: ПАНЕЛЬ ЧАТОВ ================= -->
       <!-- Задали жесткий лимит: теперь сплиттер физически упрется в барьер на ширине 320 пикселей и не пойдет дальше вправо! -->
<Border Grid.Column="0" Background="#17212B" BorderBrush="#101921" BorderThickness="0,0,1,0">
            
            <!-- Используем SplitView для реализации выезжающего бокового меню Telegram -->
            <SplitView x:Name="MenuSplitView"
                       DisplayMode="Overlay"
                       OpenPaneLength="240"
                       Background="Transparent">
                
                <!-- 1. ВНУТРЕННОСТЬ ВЫЕЗЖАЮЩЕГО МЕНЮ (Выдвигается слева) -->
               <SplitView.Pane>
                    <!-- ИСПРАВЛЕНО: Заменили StackPanel на DockPanel, чтобы жестко зафиксировать кнопку Выхода снизу -->
                    <Border Background="#17212B" BorderBrush="#101921" BorderThickness="0,0,1,0" Padding="15,20">
                        <DockPanel LastChildFill="True">
                            
                            <!-- НИЖНЯЯ КНОПКА: Выйти из аккаунта (ИСПРАВЛЕНО: Намертво прижата к НИЗУ панели) -->
                            <Button DockPanel.Dock="Bottom" 
                                    Content="🚪   Выйти из аккаунта" 
                                    Command="{Binding Logout}" 
                                    Background="Transparent" 
                                    Foreground="#E55757" 
                                    HorizontalAlignment="Stretch" 
                                    Padding="10,8" 
                                    CornerRadius="6" 
                                    FontSize="13" 
                                    Margin="0,20,0,0"/>
                            
                            <!-- СТЕНДАРТНЫЙ СТЕК: Для всех остальных верхних элементов меню -->
                            <StackPanel Spacing="0">
                                
                                <!-- Кнопка Назад (Стрелочка для закрытия меню) -->
                                <Button Name="CloseMenuBtn" Background="Transparent" Foreground="#7F91A4" Content="← Назад" FontSize="13" Margin="0,0,0,15"/>
                                
                                <!-- БЛОК ПРОФИЛЯ -->
                                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,15">
                                    <!-- Круглая фото-заглушка (ИСПРАВЛЕНО: Выводим строго MyInitials, одну букву!) -->
                                    <Border Grid.Column="0" Background="#2B5278" CornerRadius="20" Width="40" Height="40" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding MyInitials}" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MyUsername}" FontWeight="SemiBold" Foreground="White" FontSize="14"/>
                                        <TextBlock Text="Защищенная сессия X3DH" FontSize="11" Foreground="#7F91A4"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Сепаратор 1 -->
                                <Border Height="1" Background="#24303F" Margin="0,5,0,10"/>
                                
                                <!-- Кнопки Навигации меню (ИСПРАВЛЕНО: Текст покрашен в синий цвет #5288C1) -->
                                <Button Content="👤   Мой профиль" Command="{Binding OpenMyProfile}" Background="Transparent" Foreground="#5288C1" HorizontalAlignment="Stretch" Padding="10,8" CornerRadius="6" FontSize="13"/>
                                <Button Content="⚙️   Настройки" Command="{Binding OpenSettings}" Background="Transparent" Foreground="#5288C1" HorizontalAlignment="Stretch" Padding="10,8" CornerRadius="6" FontSize="13" Margin="0,4,0,0"/>
                                
                                <!-- Сепаратор 2 -->
                                <Border Height="1" Background="#24303F" Margin="0,15,0,10"/>
                                
                                <!-- Кнопка создания группы -->
                                <Button Name="CreateGroupBtn" Content="👥   Создать групповой чат" Background="Transparent" Foreground="#5288C1" HorizontalAlignment="Stretch" Padding="10,8" CornerRadius="6" FontSize="13"/>
                                
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </SplitView.Pane>

                <!-- 2. ОСНОВНОЙ КОНТЕНТ ЛЕВОЙ ПАНЕЛИ (Список чатов, который виден всегда) -->
                <Grid RowDefinitions="Auto, Auto, *">
                    
                    <!-- Верхняя панель: Кнопка БУРГЕР и Имя (ИСПРАВЛЕНО) -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="14,12,14,0">
                        <!-- Кнопка-Бургер '☰' открывает меню по клику -->
                    <Button Grid.Column="0" 
                            Name="BurgerBtn"
                            Content="☰" 
                            Background="Transparent" 
                            Foreground="#7F91A4" 
                            FontSize="18" 
                            Padding="5,2" 
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Cursor="Hand"/>
                        <TextBlock Grid.Column="1" Text="{Binding MyUsername}" Foreground="#5288C1" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Поиск / Добавление друга (Строка 1) -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="14,12">
                        <TextBox Grid.Column="0" Watermark="Введите username..." Text="{Binding NewFriendUsername}" Foreground="White" Background="#24303F" BorderThickness="0" CornerRadius="6,0,0,6" Height="34" VerticalContentAlignment="Center" Padding="10,0" FontSize="13"/>
                        <Button Grid.Column="1" Content="+" Command="{Binding AddNewChatByUsernameAsync}" Background="#5288C1" Foreground="White" Width="34" Height="34" CornerRadius="0,6,6,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    </Grid>

                    <!-- Список диалогов (Строка 2) -->
                     <ListBox Grid.Row="2" ItemsSource="{Binding Chats}" SelectedItem="{Binding SelectedChat}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="models:ChatSession">
                            
                            <!-- Контейнер карточки вернули в режим 3 колонок (Auto, *, Auto) -->
                            <Grid ColumnDefinitions="Auto, *, Auto" HorizontalAlignment="Stretch" Margin="10,4,10,4" Background="Transparent">
                                
                                <Grid.ContextMenu>
                                    <ContextMenu Background="#17212B" BorderBrush="#24303F" BorderThickness="1">
                                        <!-- Удаление со всей историей доступно строго по правому клику мыши (ПКМ) -->
                                        <MenuItem Header="🗑️ Удалить чат со всей историей" 
                                                  Foreground="#E55757" 
                                                  FontWeight="SemiBold"
                                                  Command="{Binding $parent[UserControl].DataContext.DeleteChatAsync}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>

                                <!-- Круглая заглушка аватарки (Колонка 0) -->
                                <Border Grid.Column="0" Background="#2B5278" CornerRadius="20" Width="38" Height="38" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <!-- Текст чата (Колонка 1) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding PartnerName}" FontWeight="Bold" Foreground="White" FontSize="13" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding LastMessage}" Foreground="#7F91A4" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                                
                                <!-- Колонка 2: Синий счетчик непрочитанных -->
                                <Border Grid.Column="2" Background="#5288C1" CornerRadius="10" MinHeight="18" MinWidth="18" Padding="5,2" VerticalAlignment="Center" HorizontalAlignment="Right" IsVisible="{Binding HasUnread}">
                                    <TextBlock Text="{Binding UnreadCount}" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
                
            </SplitView>
        </Border>

        <!-- ================= ДИНАМИЧЕСКИЙ РАЗДЕЛИТЕЛЬ ОКРАИН ================= -->
        <GridSplitter Grid.Column="1" 
                      Width="1" 
                      Background="#101921" 
                      ResizeDirection="Columns"
                      ShowsPreview="False"/>

        <!-- ================= СПРАВА: ОКНО ПЕРЕПИСКИ ================= -->
        <!-- ИСПРАВЛЕНО: Заменили Grid на DockPanel со свойством LastChildFill. 
             Теперь ScrollViewer гарантированно зажат между заголовком и вводом! -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *, Auto" Background="#0E1621">
            
            <!-- Строка 0: Верхний заголовок текущего чата -->
 <Border Grid.Row="0" Background="#17212B" Padding="20,8" BorderBrush="#101921" BorderThickness="0,0,0,1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    
                    <!-- Название чата / группы -->
                    <TextBlock Text="{Binding ChatHeader}" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    
                    <!-- ПОДЗАГОЛОВОК А: Если это обычный диалог (IsGroupChat = False) -> Просто пустой или обычный статус -->
                    <Border IsVisible="{Binding !IsGroupChat}" Height="0"/>

                    <!-- ПОДЗАГОЛОВОК Б: Если это ГРУППА (IsGroupChat = True) -> Показываем количество участников в виде кликабельной ссылки -->
                    <Button IsVisible="{Binding IsGroupChat}"
                            Background="Transparent" 
                            Padding="0" Margin="0,2,0,0"
                            HorizontalAlignment="Center"
                            Cursor="Hand">
                        
                        <!-- Текст счетчика -->
                        <TextBlock Text="{Binding GroupParticipantsCountText}" Foreground="#7F91A4" FontSize="11" HorizontalAlignment="Center"/>
                        
                        <!-- ВСПЛЫВАЮЩЕЕ ОКНО (TOOLTIP/FLYOUT) СО СПИСКОМ УЧАСТНИКОВ ПО КЛИКУ -->
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <!-- Контейнер всплывающего окна (Тёмный, под стиль Telegram) -->
                                <Border Background="#17212B" BorderBrush="#24303F" BorderThickness="1" CornerRadius="8" Padding="12" Width="180" MaxHeight="220">
                                    <Grid RowDefinitions="Auto, *">
                                        
                                        <!-- Заголовок всплывашки -->
                                        <TextBlock Grid.Row="0" Text="Участники:" Foreground="#7F91A4" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        
                                        <!-- Скроллбар списка (ВКЛЮЧИТСЯ АВТОМАТИЧЕСКИ, ЕСЛИ ЛЮДЕЙ МНОГО) -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding CurrentGroupMembers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type system:String}">
                                                        <!-- Строка участника: Иконка + Имя -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                                            <TextBlock Text="•" Foreground="#5288C1" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        
                                    </Grid>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    
                </StackPanel>
            </Border>

            <!-- Строка 1: Лента сообщений -->
            <ScrollViewer x:Name="ChatScrollViewer" 
                          Grid.Row="1" 
                          Padding="14,10,14,0" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          ClipToBounds="True">
                
                <ItemsControl ItemsSource="{Binding Messages}" ClipToBounds="True" Margin="0,0,0,0" Padding="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                            <Grid>
                                
                                <!-- ВАРИАНТ А: ПЛАШКА С ДАТОЙ -->
                                <Border HorizontalAlignment="Center" 
                                        Background="#1C2833" 
                                        CornerRadius="10" 
                                        Padding="14,4" 
                                        Margin="0,10"
                                        IsVisible="{Binding IsDateSeparator}">
                                    <TextBlock Text="{Binding FormattedDate}" 
                                               Foreground="#7F91A4" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- ВАРИАНТ Б: СТАНДАРТНОЕ СООБЩЕНИЕ -->
                                <Grid ColumnDefinitions="Auto, *" 
                                      HorizontalAlignment="Left" 
                                      Margin="0,5"
                                      IsVisible="{Binding !IsDateSeparator}">
                                    
                                    <Panel Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Border Width="30" Height="30" CornerRadius="15" BorderThickness="2" IsVisible="{Binding IsMe}">
                                            <Border.BorderBrush>
                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                    <GradientStop Color="#8A2BE2" Offset="0.0"/>
                                                    <GradientStop Color="#1E90FF" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.BorderBrush>
                                            <Border Background="#1A2C3B" CornerRadius="13">
                                                <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Border>
                                        <Border Width="30" Height="30" CornerRadius="15" Background="#1A2C3B" BorderBrush="#7F91A4" BorderThickness="1" IsVisible="{Binding !IsMe}">
                                            <TextBlock Text="{Binding Initials}" Foreground="#7F91A4" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Panel>
                                    
                                    <Border Grid.Column="1" CornerRadius="10" Padding="12,7" MaxWidth="380" Background="{Binding BubbleColor}" BorderBrush="{Binding BorderColor}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" FontSize="9" Foreground="#7F91A4" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                </Grid>
                                
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- КРУГЛАЯ КНОПКА ДЛЯ СКРОЛЛА ВНИЗ В СТИЛЕ TELEGRAM -->
            <!-- ИСПРАВЛЕНО: Кнопка лежит строго в Grid.Row="1" поверх скроллбара. 
                 Она больше не сжимает окна, а парит в углу за счет Margin -->
            <Button Name="ScrollDownBtn"
                    Grid.Row="1"
                    IsVisible="{Binding IsScrollButtonVisible}"
                    Width="38" Height="38" 
                    CornerRadius="19" 
                    Background="#17212B" 
                    BorderBrush="#2B5278" 
                    BorderThickness="1"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,25,20">
                <TextBlock Text="▼" 
                           Foreground="#5288C1" 
                           FontSize="13" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="0,1,0,0"/>
            </Button>

            <!-- Строка 2: Нижняя панель ввода текста -->
<Border x:Name="InputPanelBorder" 
                    Grid.Row="2" 
                    Background="#17212B" 
                    Padding="12,10" 
                    VerticalAlignment="Bottom"
                    BorderBrush="#101921" 
                    BorderThickness="0,1,0,0"
                    IsVisible="{Binding IsChatSelected}">
                <Grid ColumnDefinitions="*, Auto" Background="#17212B">
                    
                    <!-- Поле ввода текста (ИСПРАВЛЕНО: Добавлена привязка к клавише Enter) -->
                    <TextBox Grid.Column="0" 
                             Watermark="Написать сообщение..." 
                             Text="{Binding TypedText}" 
                             Foreground="White" 
                             Background="#24303F" 
                             BorderThickness="0" 
                             CornerRadius="6" 
                             Padding="12,8" 
                             MaxHeight="80" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="False" 
                             FontSize="13">
                        <TextBox.KeyBindings>
                            <!-- Нажатие Enter на клавиатуре мгновенно вызывает метод SendMessageAsync -->
                            <KeyBinding Gesture="Enter" Command="{Binding SendMessageAsync}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    
                    <!-- КНОПКА ОТПРАВИТЬ С БУМАЖНЫМ САМОЛЕТИКОМ (ИСПРАВЛЕНО: Сделана круглой под стиль Telegram) -->
                    <!-- КНОПКА ОТПРАВИТЬ С ОРИГИНАЛЬНЫМ ВЕКТОРНЫМ САМОЛЕТИКОМ TELEGRAM -->
                    <Button x:Name="SendButton" 
                            Grid.Column="1"
                            Command="{Binding SendMessageAsync}"
                            Background="#5288C1"
                            BorderThickness="0"
                            CornerRadius="20"
                            Width="40"
                            Height="40"
                            Cursor="Hand"
                            Padding="0"
                            Margin="10,0,2,0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            VerticalAlignment="Center">
                        <!-- Векторная SVG-иконка самолетика (Идеальная четкость на любых экранах) -->
                        <Path Data="M2,21 L23,12 L2,3 L2,10 L17,12 L2,14 L2,21 Z"
                              Fill="White"
                              Width="18"
                              Height="18"
                              Stretch="Uniform"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                    </Button>

                    
                </Grid>
            </Border>
            
        </Grid> <!-- Конец правой панели -->

        <!-- ================= МОДАЛЬНОЕ ОКНО СОЗДАНИЯ ГРУППЫ ================= -->
        <!-- Размещено в ColumnSpan="3", чтобы полностью перекрыть и левую, и правую панель -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3" 
              Background="#A0000000" 
              IsVisible="{Binding IsCreateGroupWindowVisible}"
              VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            
            <!-- Сама карточка по центру экрана -->
            <Border Background="#17212B" 
                    BorderBrush="#24303F" BorderThickness="1" 
                    CornerRadius="12" 
                    Width="340" Height="460"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="20">
                <Grid RowDefinitions="Auto, Auto, *, Auto">
                    
                    <!-- Шапка окна -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                        <TextBlock Grid.Column="0" Text="Создание группы" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" Command="{Binding CancelGroupCreation}" Background="Transparent" Foreground="#7F91A4" FontSize="16"/>
                    </Grid>
                    
                    <!-- Поле ввода названия группы -->
                    <TextBox Grid.Row="1" 
                             Watermark="Название группы" 
                             Text="{Binding NewGroupName}"
                             Foreground="White" Background="#24303F"
                             BorderThickness="0" CornerRadius="6" Padding="10,8" Margin="0,0,0,15"/>
                    
                    <!-- Список друзей с прокруткой для выбора участников -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <ItemsControl ItemsSource="{Binding AvailableFriends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:GroupMemberSelection">
                                    <!-- Элемент выбора: Аватарка + Ник + Синяя галочка CheckBox -->
                                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,4">
                                        <Border Grid.Column="0" Background="#2B5278" CornerRadius="16" Width="32" Height="32" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                        
                                        <!-- Синий кастомный CheckBox (Галочка) -->
                                        <CheckBox Grid.Column="2" 
                                                  IsChecked="{Binding IsSelected}" 
                                                  VerticalAlignment="Center"
                                                  MinWidth="0" Padding="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Нижняя кнопка "Создать" -->
                    <Button Grid.Row="3" 
                            Content="Создать группу" 
                            Command="{Binding ConfirmCreateGroupAsync}"
                            Background="#5288C1" Foreground="White"
                            FontWeight="SemiBold" FontSize="14"
                            Height="38" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            CornerRadius="6"/>
                    
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
