<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SecureCryptoClient.ViewModels"
             xmlns:models="using:SecureCryptoClient.Models"
             xmlns:system="using:System"
             x:Class="SecureCryptoClient.Views.MainChatView"
             x:DataType="vm:MainChatViewModel"
             Background="#0F0F1A">

<!-- ================= СТИЛЬ ВЫДЕЛЕНИЯ ЧАТА (ФИНАЛЬНЫЙ) ================= -->
<UserControl.Styles>
    <Style Selector="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Hover -->
    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="#1F1F2E" />
    </Style>

    <!-- Выбранный чат -->
    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="#2A2A3F" />
        <Setter Property="BorderBrush" Value="#6366F1" />
        <Setter Property="BorderThickness" Value="2,0,0,0" />
    </Style>

    <!-- Hover на выбранном -->
    <Style Selector="ListBoxItem:selected:pointerover">
        <Setter Property="Background" Value="#2A2A45" />
    </Style>

    <!-- Убираем стандартное выделение Avalonia -->
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</UserControl.Styles>
    
<Grid ColumnDefinitions="260, 1, *">
        
        <!-- ================= СЛЕВА: ПАНЕЛЬ ЧАТОВ ================= -->
        <Border Grid.Column="0" Background="#181824" BorderBrush="#0F0F1A" BorderThickness="0,0,1,0">
            
            <SplitView x:Name="MenuSplitView"
                       DisplayMode="Overlay"
                       OpenPaneLength="240"
                       Background="Transparent">
                
                <!-- 1. Выезжающее меню -->
                <SplitView.Pane>
                    <Border Background="#181824" BorderBrush="#0F0F1A" BorderThickness="0,0,1,0" Padding="15,20">
                        <DockPanel LastChildFill="True">
                            
                            <Button DockPanel.Dock="Bottom" 
                                    Content="🚪   Выйти из аккаунта" 
                                    Command="{Binding Logout}" 
                                    Background="Transparent" 
                                    Foreground="#E55757" 
                                    HorizontalAlignment="Stretch" 
                                    Padding="10,8" 
                                    CornerRadius="6" 
                                    FontSize="13" 
                                    Margin="0,20,0,0"/>
                            
                            <StackPanel Spacing="0">
                                <Button Name="CloseMenuBtn" Background="Transparent" Foreground="#B4B3D0" Content="← Назад" FontSize="13" Margin="0,0,0,15"/>
                                
                                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,15">
                                    <Border Grid.Column="0" Background="#2A2A3F" CornerRadius="20" Width="40" Height="40" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding MyInitials}" Foreground="#F1F0FF" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MyUsername}" FontWeight="SemiBold" Foreground="#F1F0FF" FontSize="14"/>
                                        <TextBlock Text="Защищенная сессия X3DH" FontSize="11" Foreground="#7C7B9E"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Border Height="1" Background="#25253A" Margin="0,5,0,10"/>
                                
                                <Button Content="👤   Мой профиль" Command="{Binding OpenMyProfile}" Background="Transparent" Foreground="#8184FF" HorizontalAlignment="Stretch" Padding="10,8" CornerRadius="6" FontSize="13"/>
                                <Button Content="⚙️   Настройки" Command="{Binding OpenSettings}" Background="Transparent" Foreground="#8184FF" HorizontalAlignment="Stretch" Padding="10,8" CornerRadius="6" FontSize="13" Margin="0,4,0,0"/>
                                
                                <Border Height="1" Background="#25253A" Margin="0,15,0,10"/>
                                
                                <Button Name="CreateGroupBtn" Content="👥   Создать групповой чат" Background="Transparent" Foreground="#8184FF" HorizontalAlignment="Stretch" Padding="10,8" CornerRadius="6" FontSize="13"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </SplitView.Pane>

                <!-- 2. Основная левая панель -->
                <Grid RowDefinitions="Auto, Auto, *">
                    
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="14,12,14,0">
                        <Button Grid.Column="0" Name="BurgerBtn" Content="☰" Background="Transparent" Foreground="#B4B3D0" FontSize="18" Padding="5,2" Margin="0,0,10,0" VerticalAlignment="Center" Cursor="Hand"/>
                        <TextBlock Grid.Column="1" Text="{Binding MyUsername}" Foreground="#8184FF" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="14,12">
                        <TextBox Grid.Column="0" Watermark="Введите username..." Text="{Binding NewFriendUsername}" 
                                 Foreground="#F1F0FF" Background="#1F1F2E" BorderThickness="0" 
                                 CornerRadius="6,0,0,6" Height="34" VerticalContentAlignment="Center" Padding="10,0" FontSize="13"/>
                        <Button Grid.Column="1" Content="+" Command="{Binding AddNewChatByUsernameAsync}" 
                                Background="#6366F1" Foreground="White" Width="34" Height="34" 
                                CornerRadius="0,6,6,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                                FontSize="16" FontWeight="Bold"/>
                    </Grid>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Chats}" SelectedItem="{Binding SelectedChat}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:ChatSession">
                                <Grid ColumnDefinitions="Auto, *, Auto" HorizontalAlignment="Stretch" Margin="10,4,10,4" Background="Transparent">
                                    <Grid.ContextMenu>
                                        <ContextMenu Background="#181824" BorderBrush="#25253A" BorderThickness="1">
                                            <MenuItem Header="🗑️ Удалить чат со всей историей" 
                                                      Foreground="#E55757" FontWeight="SemiBold"
                                                      Command="{Binding $parent[UserControl].DataContext.DeleteChatAsync}"
                                                      CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <Border Grid.Column="0" Background="#2A2A3F" CornerRadius="20" Width="38" Height="38" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Initials}" Foreground="#F1F0FF" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding PartnerName}" FontWeight="Bold" Foreground="#F1F0FF" FontSize="13" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding LastMessage}" Foreground="#B4B3D0" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Column="2" Background="#6366F1" CornerRadius="10" MinHeight="18" MinWidth="18" Padding="5,2" 
                                            VerticalAlignment="Center" HorizontalAlignment="Right" IsVisible="{Binding HasUnread}">
                                        <TextBlock Text="{Binding UnreadCount}" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </SplitView>
        </Border>

        <GridSplitter Grid.Column="1" Width="1" Background="#0F0F1A" ResizeDirection="Columns" ShowsPreview="False"/>

        <!-- ================= СПРАВА: ЧАТ ================= -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *, Auto" Background="#0F0F1A">
            
            <Border Grid.Row="0" Background="#181824" Padding="20,8" BorderBrush="#0F0F1A" BorderThickness="0,0,0,1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ChatHeader}" Foreground="#F1F0FF" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    
                    <Button IsVisible="{Binding IsGroupChat}" Background="Transparent" Padding="0" Margin="0,2,0,0" HorizontalAlignment="Center" Cursor="Hand">
                        <TextBlock Text="{Binding GroupParticipantsCountText}" Foreground="#B4B3D0" FontSize="11" HorizontalAlignment="Center"/>
                        <Button.Flyout>
                            <Flyout Placement="Bottom">
                                <Border Background="#181824" BorderBrush="#25253A" BorderThickness="1" CornerRadius="8" Padding="12" Width="180" MaxHeight="220">
                                    <Grid RowDefinitions="Auto, *">
                                        <TextBlock Grid.Row="0" Text="Участники:" Foreground="#7C7B9E" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding CurrentGroupMembers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type system:String}">
                                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                                            <TextBlock Text="•" Foreground="#6366F1" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding}" Foreground="#F1F0FF" FontSize="13" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" Padding="14,10,14,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding Messages}" ClipToBounds="True" Margin="0,0,0,0" Padding="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ChatMessage}">
                            <Grid>
                                <Border HorizontalAlignment="Center" Background="#1F1F2E" CornerRadius="10" Padding="14,4" Margin="0,10" IsVisible="{Binding IsDateSeparator}">
                                    <TextBlock Text="{Binding FormattedDate}" Foreground="#7C7B9E" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <Grid ColumnDefinitions="Auto, *" HorizontalAlignment="Left" Margin="0,5" 
                                      IsVisible="{Binding !IsDateSeparator}">
    
                                    <Panel Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <!-- Аватар -->
                                        <Border Width="30" Height="30" CornerRadius="15" BorderThickness="2" IsVisible="{Binding IsMe}">
                                            <Border.BorderBrush>
                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                    <GradientStop Color="#6366F1" Offset="0.0"/>
                                                    <GradientStop Color="#8184FF" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.BorderBrush>
                                            <Border Background="#1F1F2E" CornerRadius="13">
                                                <TextBlock Text="{Binding Initials}" Foreground="#F1F0FF" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Border>
        
                                        <Border Width="30" Height="30" CornerRadius="15" Background="#1F1F2E" BorderBrush="#2A2A3F" BorderThickness="1" 
                                                IsVisible="{Binding !IsMe}">
                                            <TextBlock Text="{Binding Initials}" Foreground="#B4B3D0" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Panel>
    
                                    <!-- === ОТПРАВЛЕННЫЕ СООБЩЕНИЯ (МОИ) === -->
                                    <Border Grid.Column="1" CornerRadius="10" Padding="12,7" MaxWidth="380" BorderThickness="1"
                                            IsVisible="{Binding IsMe}"
                                            Background="#6366F1">
                                        <!-- Градиент для моих сообщений -->
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                <GradientStop Color="#6366F1" Offset="0.0"/>
                                                <GradientStop Color="#4F46E5" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
        
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#8184FF" Opacity="0.7"/>
                                        </Border.BorderBrush>
        
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" FontSize="13" Foreground="#F1F0FF" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" FontSize="9" Foreground="#E0DFFF" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- === ВХОДЯЩИЕ СООБЩЕНИЯ === -->
                                    <Border Grid.Column="1" CornerRadius="10" Padding="12,7" MaxWidth="380" BorderThickness="1"
                                                IsVisible="{Binding !IsMe}"
                                                Background="#21213A"
                                                BorderBrush="#2F2F4F">
        
                                            <StackPanel>
                                                <TextBlock Text="{Binding Text}" FontSize="13" Foreground="#F1F0FF" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" FontSize="9" Foreground="#7C7B9E" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
    
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Name="ScrollDownBtn" Grid.Row="1" IsVisible="{Binding IsScrollButtonVisible}"
                    Width="38" Height="38" CornerRadius="19" Background="#181824" BorderBrush="#2A2A3F" 
                    BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,25,20">
                <TextBlock Text="▼" Foreground="#8184FF" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,1,0,0"/>
            </Button>

            <Border x:Name="InputPanelBorder" Grid.Row="2" Background="#181824" Padding="12,10" 
                    VerticalAlignment="Bottom" BorderBrush="#0F0F1A" BorderThickness="0,1,0,0" IsVisible="{Binding IsChatSelected}">
                <Grid ColumnDefinitions="*, Auto" Background="#181824">
                    <TextBox Grid.Column="0" Watermark="Написать сообщение..." Text="{Binding TypedText}" 
                             Foreground="#F1F0FF" Background="#1F1F2E" BorderThickness="0" CornerRadius="6" 
                             Padding="12,8" MaxHeight="80" TextWrapping="Wrap" AcceptsReturn="False" FontSize="13">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SendMessageAsync}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    
                    <Button x:Name="SendButton" Grid.Column="1" Command="{Binding SendMessageAsync}"
                            Background="#6366F1" BorderThickness="0" CornerRadius="20" Width="40" Height="40"
                            Cursor="Hand" Padding="0" Margin="10,0,2,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Path Data="M2,21 L23,12 L2,3 L2,10 L17,12 L2,14 L2,21 Z" Fill="White" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Модальное окно создания группы -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3" Background="#A0000000" IsVisible="{Binding IsCreateGroupWindowVisible}">
            <Border Background="#181824" BorderBrush="#25253A" BorderThickness="1" CornerRadius="12" 
                    Width="340" Height="460" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <Grid RowDefinitions="Auto, Auto, *, Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                        <TextBlock Grid.Column="0" Text="Создание группы" Foreground="#F1F0FF" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" Command="{Binding CancelGroupCreation}" Background="Transparent" Foreground="#B4B3D0" FontSize="16"/>
                    </Grid>
                    
                    <TextBox Grid.Row="1" Watermark="Название группы" Text="{Binding NewGroupName}"
                             Foreground="#F1F0FF" Background="#1F1F2E" BorderThickness="0" CornerRadius="6" Padding="10,8" Margin="0,0,0,15"/>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <ItemsControl ItemsSource="{Binding AvailableFriends}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:GroupMemberSelection">
                                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,4">
                                        <Border Grid.Column="0" Background="#2A2A3F" CornerRadius="16" Width="32" Height="32" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="#F1F0FF" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="#F1F0FF" FontSize="14" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" MinWidth="0" Padding="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <Button Grid.Row="3" 
                                        Content="Создать группу" 
                                        Command="{Binding ConfirmCreateGroupAsync}"
                                        Background="#6366F1" 
                                        Foreground="White"
                                        FontWeight="SemiBold" 
                                        FontSize="14"
                                        Height="38" 
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="6"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>