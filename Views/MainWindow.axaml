<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SecureCryptoClient.ViewModels"
        xmlns:views="using:SecureCryptoClient.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:securecryptoclient="using:SecureCryptoClient"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SecureCryptoClient.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="400" Height="550"
        Title="SecureCryptoClient"
        WindowStartupLocation="CenterScreen">

    <!-- ContentControl автоматически переключает экраны, считывая их из папки Views -->
    <ContentControl Content="{Binding CurrentContent}">
        <ContentControl.DataTemplates>
            
            <!-- Если в CurrentContent лежит AuthViewModel -> показываем AuthView -->
            <DataTemplate DataType="{x:Type vm:AuthViewModel}">
                <securecryptoclient:AuthView />
            </DataTemplate>
            
            <!-- Если в CurrentContent лежит MainChatViewModel -> показываем MainChatView -->
            <DataTemplate DataType="{x:Type vm:MainChatViewModel}">
                <views:MainChatView />
            </DataTemplate>
            
        </ContentControl.DataTemplates>
    </ContentControl>
</Window>
